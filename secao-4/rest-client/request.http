@baseUrl = http://localhost:3000

### Auth login
# @name authLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
 "email": "user@email.com",
 "password": "123456"
}

### Read one user
# @name readOneUser
GET {{baseUrl}}/user/123

### Create user
# @name createuser
POST {{baseUrl}}/user
Content-Type: application/json

{
  "name": "Lanita",
  "email": "lanita@email.com",
  "password": "123123"
}
